<%- include('../partials/head', { title: visa.title + ' - Hikma' }) %>

<body class="smooth-scroll-yes">
    <div id="preloader" class="preloader">
        <div class="animation-preloader">
            <div class="spinner"></div>
            <div class="txt-loading">
                <span data-text-preloader="H" class="letters-loading">H</span>
                <span data-text-preloader="I" class="letters-loading">I</span>
                <span data-text-preloader="K" class="letters-loading">K</span>
                <span data-text-preloader="M" class="letters-loading">M</span>
                <span data-text-preloader="A" class="letters-loading">A</span>
            </div>
            <p class="text-center">Loading</p>
        </div>
        <div class="loader">
            <div class="row">
                <div class="col-3 loader-section section-left"><div class="bg"></div></div>
                <div class="col-3 loader-section section-left"><div class="bg"></div></div>
                <div class="col-3 loader-section section-right"><div class="bg"></div></div>
                <div class="col-3 loader-section section-right"><div class="bg"></div></div>
            </div>
        </div>
    </div>
    <button id="back-top" class="back-to-top show"><i class="fa-regular fa-arrow-up"></i></button>
    <%- include('../partials/header') %>

    <section class="breadcrumb-wrapper fix bg-cover" style="background-image: url('/assets/img/inner-page/breadcrumb.jpg');">
        <div class="container">
            <div class="page-heading">
                <h1 class="breadcrumb-title"><% if (visa.flag) { %><%= visa.flag %> <% } %><%= visa.title %></h1>
                <ul class="breadcrumb-list">
                    <li><a href="/">الرئيسية</a></li>
                    <li><i class="fa-solid fa-chevron-right"></i></li>
                    <li><a href="/visas">التأشيرات</a></li>
                    <li><i class="fa-solid fa-chevron-right"></i></li>
                    <li><%= visa.title %></li>
                </ul>
            </div>
        </div>
    </section>

    <section class="news-standard-section section-padding fix" dir="rtl">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-8 col-12 text-right">
                    <div class="news-standard-post p-4" style="border: 1px solid #e7e7e7; border-radius: 18px;">
                        <img src="<%= visa.image %>" alt="<%= visa.title %>" style="width: 100%; border-radius: 18px; margin-bottom: 20px;">
                        <p><%= visa.description %></p>
                        <div class="mt-4">
                            <h4>المتطلبات الأساسية</h4>
                            <ul style="padding: 0; list-style: none;">
                                <% visa.requirements.forEach(requirement => { %>
                                    <li style="margin-bottom: 10px;"><i class="fa-solid fa-check"></i> <%= requirement %></li>
                                <% }) %>
                            </ul>
                        </div>
                        <div class="mt-4">
                            <h4>نصائح مهمة</h4>
                            <ul style="padding: 0; list-style: none;">
                                <% visa.tips.forEach(tip => { %>
                                    <li style="margin-bottom: 10px;"><i class="fa-solid fa-lightbulb"></i> <%= tip %></li>
                                <% }) %>
                            </ul>
                        </div>

                        <% if (visa.tuition && visa.tuition.length) { %>
                        <div class="mt-4">
                            <h4>رسوم الدراسة حسب التخصص</h4>
                            <div class="row g-3">
                                <% visa.tuition.forEach(item => { %>
                                    <div class="col-md-6 col-12">
                                        <div style="background:#f9f9f9; border-radius:12px; padding:14px 16px; display:flex; justify-content:space-between; align-items:center;">
                                            <span style="font-weight:600;"><%= item.label %></span>
                                            <span style="color:#cc181e; font-weight:600;"><%= item.value %></span>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        </div>
                        <% } %>

                        <% if (visa.livingCost) { %>
                        <div class="mt-4">
                            <h4>تكلفة المعيشة</h4>
                            <div class="row g-3 text-center">
                                <% if (visa.livingCost.residence) { %>
                                <div class="col-6 col-md-3">
                                    <div style="border:1px solid #e7e7e7; border-radius:12px; padding:16px 10px;">
                                        <i class="fa-solid fa-building" style="color:#cc181e; font-size:20px;"></i>
                                        <div style="font-size:13px; margin-top:8px;">سكن جامعي</div>
                                        <div style="font-weight:600; font-size:14px;"><%= visa.livingCost.residence %></div>
                                    </div>
                                </div>
                                <% } %>
                                <% if (visa.livingCost.apartment) { %>
                                <div class="col-6 col-md-3">
                                    <div style="border:1px solid #e7e7e7; border-radius:12px; padding:16px 10px;">
                                        <i class="fa-solid fa-house" style="color:#cc181e; font-size:20px;"></i>
                                        <div style="font-size:13px; margin-top:8px;">شقة خاصة</div>
                                        <div style="font-weight:600; font-size:14px;"><%= visa.livingCost.apartment %></div>
                                    </div>
                                </div>
                                <% } %>
                                <% if (visa.livingCost.food) { %>
                                <div class="col-6 col-md-3">
                                    <div style="border:1px solid #e7e7e7; border-radius:12px; padding:16px 10px;">
                                        <i class="fa-solid fa-utensils" style="color:#cc181e; font-size:20px;"></i>
                                        <div style="font-size:13px; margin-top:8px;">التغذية</div>
                                        <div style="font-weight:600; font-size:14px;"><%= visa.livingCost.food %></div>
                                    </div>
                                </div>
                                <% } %>
                                <% if (visa.livingCost.transport) { %>
                                <div class="col-6 col-md-3">
                                    <div style="border:1px solid #e7e7e7; border-radius:12px; padding:16px 10px;">
                                        <i class="fa-solid fa-bus" style="color:#cc181e; font-size:20px;"></i>
                                        <div style="font-size:13px; margin-top:8px;">النقل</div>
                                        <div style="font-weight:600; font-size:14px;"><%= visa.livingCost.transport %></div>
                                    </div>
                                </div>
                                <% } %>
                            </div>
                            <% if (visa.livingCost.total) { %>
                                <div style="margin-top:14px; background:#fdecec; border-radius:12px; padding:14px 18px; font-weight:700; color:#cc181e; text-align:center;">
                                    الميزانية الشهرية الإجمالية: <%= visa.livingCost.total %>
                                </div>
                            <% } %>
                        </div>
                        <% } %>

                        <% if (visa.topUniversities && visa.topUniversities.length) { %>
                        <div class="mt-4">
                            <h4>أفضل الجامعات</h4>
                            <div style="display:flex; flex-wrap:wrap; gap:10px;">
                                <% visa.topUniversities.forEach(uni => { %>
                                    <span style="background:#f2f2f2; border-radius:30px; padding:8px 16px; font-size:14px;"><i class="fa-solid fa-graduation-cap" style="color:#cc181e; margin-left:6px;"></i><%= uni %></span>
                                <% }) %>
                            </div>
                        </div>
                        <% } %>

                        <% if (visa.faq && visa.faq.length) { %>
                        <div class="mt-4">
                            <h4>الأسئلة الشائعة</h4>
                            <div class="accordion" id="visaFaqAccordion">
                                <% visa.faq.forEach((item, i) => { %>
                                    <div style="border:1px solid #e7e7e7; border-radius:12px; margin-bottom:10px; overflow:hidden;">
                                        <button class="btn" data-bs-toggle="collapse" data-bs-target="#faq-<%= visa.id %>-<%= i %>" style="width:100%; text-align:right; padding:14px 18px; font-weight:600; background:#fafafa; border:none;">
                                            <%= item.q %>
                                        </button>
                                        <div id="faq-<%= visa.id %>-<%= i %>" class="collapse" data-bs-parent="#visaFaqAccordion">
                                            <div style="padding:14px 18px; color:#555;"><%= item.a %></div>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        </div>
                        <% } %>
                    </div>
                </div>
                <div class="col-lg-4 col-12">
                    <div class="news-sideber-box text-right p-4" style="border: 1px solid #e7e7e7; border-radius: 18px;">
                        <h4>وجهات أخرى</h4>
                        <ul style="padding: 0; list-style: none;">
                            <% if (typeof allVisas !== 'undefined') { %>
                                <% allVisas.filter(v => v.id !== visa.id).forEach(v => { %>
                                    <li style="margin-bottom:10px;"><a href="/visas/<%= v.id %>"><% if (v.flag) { %><%= v.flag %> <% } %><%= v.title %></a></li>
                                <% }) %>
                            <% } %>
                        </ul>
                        <hr>
                        <h4>تنقل سريع</h4>
                        <ul style="padding: 0; list-style: none;">
                            <li><a href="/services">خدماتنا</a></li>
                            <li><a href="/majors">التخصصات</a></li>
                            <li><a href="/contact">اتصل بنا</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <%- include('../partials/footer') %>
    <%- include('../partials/scripts') %>
</body>
</html>


