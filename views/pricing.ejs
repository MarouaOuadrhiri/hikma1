<style>
/* Mega Menu Custom Styles */
@media (min-width: 1200px) {
    .header-main {
        position: relative !important;
    }
    .header-main .main-menu ul li.mega-menu-parent {
        position: static !important;
    }
    .header-main .main-menu ul li.mega-menu-parent .mega-submenu {
        width: 100% !important;
        left: 0 !important;
        right: 0 !important;
        top: 100% !important;
        padding: 0 !important;
        border-radius: 0 0 15px 15px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.1) !important;
        transform-origin: top center !important;
        transition: all 0.3s ease-in-out !important;
        /* Force hidden by default */
        visibility: hidden !important;
        opacity: 0 !important;
        transform: scaleY(0) translateZ(0px) !important;
    }
    /* Explicitly force display on hover */
    .header-main .main-menu ul li.mega-menu-parent:hover .mega-submenu {
        visibility: visible !important;
        opacity: 1 !important;
        transform: scaleY(1) translateZ(0px) !important;
    }
}
@media (max-width: 1199px) {
    .mega-submenu {
        width: 100% !important;
    }
}

.mega-menu-title {
    font-size: 16px;
    font-weight: 700;
    color: #174093; /* brand color */
    margin-bottom: 15px;
    padding-bottom: 8px;
    border-bottom: 2px solid #f0f0f0;
    text-align: right;
}

.mega-menu-list {
    list-style: none;
    padding: 0;
    margin: 0;
}

.mega-menu-list li {
    margin-bottom: 10px;
}

/* Ensure mega menu links override default submenu link styles */
.header-main .main-menu ul li .mega-submenu li a:not(.theme-btn) {
    color: #555 !important;
    font-size: 14px !important;
    font-weight: 500 !important;
    text-decoration: none;
    transition: 0.3s;
    display: block;
    padding: 0 !important;
    text-transform: none !important;
    text-align: right !important;
}

.header-main .main-menu ul li .mega-submenu li a:not(.theme-btn):hover {
    color: #cc181e !important; /* brand red */
    padding-right: 5px !important;
}

.mega-submenu .theme-btn:hover {
    background-color: #cc181e !important;
    color: #fff !important;
}
</style>

