<%- include('../partials/head', { title: 'خدمات Hikma - Hikma' }) %>

<body class="smooth-scroll-yes">
    <div id="preloader" class="preloader">
        <div class="animation-preloader">
            <div class="spinner"></div>
            <div class="txt-loading">
                <span data-text-preloader="H" class="letters-loading">H</span>
                <span data-text-preloader="I" class="letters-loading">I</span>
                <span data-text-preloader="K" class="letters-loading">K</span>
                <span data-text-preloader="M" class="letters-loading">M</span>
                <span data-text-preloader="A" class="letters-loading">A</span>
            </div>
            <p class="text-center">Loading</p>
        </div>
        <div class="loader">
            <div class="row">
                <div class="col-3 loader-section section-left"><div class="bg"></div></div>
                <div class="col-3 loader-section section-left"><div class="bg"></div></div>
                <div class="col-3 loader-section section-right"><div class="bg"></div></div>
                <div class="col-3 loader-section section-right"><div class="bg"></div></div>
            </div>
        </div>
    </div>
    <button id="back-top" class="back-to-top show"><i class="fa-regular fa-arrow-up"></i></button>
    <%- include('../partials/header') %>

    <section class="breadcrumb-wrapper fix bg-cover" style="background-image: url('/assets/img/inner-page/breadcrumb.jpg');">
        <div class="container">
            <div class="page-heading">
                <h1 class="breadcrumb-title">خدمات Hikma</h1>
                <ul class="breadcrumb-list">
                    <li><a href="/">الرئيسية</a></li>
                    <li><i class="fa-solid fa-chevron-right"></i></li>
                    <li>خدماتنا</li>
                </ul>
            </div>
        </div>
    </section>

    <section class="news-standard-section section-padding fix" dir="rtl">
        <div class="container">
            <div class="section-title text-right mb-5">
                <span>خدمات شاملة</span>
                <h2>دعم متكامل من القبول حتى الإقامة</h2>
                <p>نقدم خدماتنا بدعم احترافي لضمان ملف قبول متكامل وسفر دراسي منظم.</p>
            </div>
            <div class="row g-4">
                <% services.forEach(service => { %>
                    <div class="col-lg-6 col-12">
                        <div class="news-standard-post" style="border: 1px solid #e7e7e7; border-radius: 20px; overflow: hidden;">
                            <div class="news-image">
                                <img src="/<%= service.image.replace(/^\//, '') %>" alt="<%= service.name %>">
                            </div>
                            <div class="news-content text-right p-4">
                                <h3><a href="/services/<%= service.id %>"><%= service.name %></a></h3>
                                <p><%= service.description %></p>
                                <a href="/services/<%= service.id %>" class="theme-btn">أكتشف الخدمة</a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
    </section>

    <%- include('../partials/footer') %>
    <%- include('../partials/scripts') %>
</body>
</html>


