<%- include('../partials/head', { title: blog.title + ' - Hikma' }) %>

<body class="smooth-scroll-yes">
    <div id="preloader" class="preloader">
        <div class="animation-preloader">
            <div class="spinner"></div>
            <div class="txt-loading">
                <span data-text-preloader="H" class="letters-loading">H</span>
                <span data-text-preloader="I" class="letters-loading">I</span>
                <span data-text-preloader="K" class="letters-loading">K</span>
                <span data-text-preloader="M" class="letters-loading">M</span>
                <span data-text-preloader="A" class="letters-loading">A</span>
            </div>
            <p class="text-center">Loading</p>
        </div>
        <div class="loader">
            <div class="row">
                <div class="col-3 loader-section section-left"><div class="bg"></div></div>
                <div class="col-3 loader-section section-left"><div class="bg"></div></div>
                <div class="col-3 loader-section section-right"><div class="bg"></div></div>
                <div class="col-3 loader-section section-right"><div class="bg"></div></div>
            </div>
        </div>
    </div>
    <button id="back-top" class="back-to-top show"><i class="fa-regular fa-arrow-up"></i></button>
    <%- include('../partials/header') %>

    <section class="breadcrumb-wrapper fix bg-cover" style="background-image: url('/assets/img/inner-page/breadcrumb.jpg');">
        <div class="container">
            <div class="page-heading">
                <h1 class="breadcrumb-title"><%= blog.title %></h1>
                <ul class="breadcrumb-list">
                    <li><a href="/">الرئيسية</a></li>
                    <li><i class="fa-solid fa-chevron-right"></i></li>
                    <li><a href="/blog">المدونة</a></li>
                    <li><i class="fa-solid fa-chevron-right"></i></li>
                    <li><%= blog.title %></li>
                </ul>
            </div>
        </div>
    </section>

    <section class="news-standard-section section-padding fix" dir="rtl">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-8 col-12 text-right">
                    <article class="news-standard-post p-4" style="border: 1px solid #e7e7e7; border-radius: 18px;">
                        <img src="<%= blog.image %>" alt="<%= blog.title %>" style="width: 100%; border-radius: 18px; margin-bottom: 20px;">
                        <div class="news-list" style="justify-content: flex-start; gap: 10px; padding: 0; margin-bottom: 15px;">
                            <span><i class="fa-solid fa-user"></i> <%= blog.author %></span>
                            <span><i class="fa-solid fa-calendar-days"></i> <%= blog.date %></span>
                            <span><i class="fa-solid fa-tags"></i> <%= blog.category %></span>
                            <span><i class="fa-solid fa-clock"></i> <%= blog.readTime %></span>
                        </div>
                        <p><%= blog.fullContent %></p>
                        <div class="mt-4">
                            <h4>العلامات</h4>
                            <div class="d-flex flex-wrap" style="gap: 10px;">
                                <% blog.tags.forEach(tag => { %>
                                    <span class="badge" style="background: #174093; color:#fff; padding: 8px 12px; border-radius: 12px;"><%= tag %></span>
                                <% }) %>
                            </div>
                        </div>
                    </article>
                </div>
                <div class="col-lg-4 col-12">
                    <div class="news-sideber-box p-4" style="border: 1px solid #e7e7e7; border-radius: 18px;">
                        <h4>مقالات أخرى</h4>
                        <ul style="padding: 0; list-style: none;">
                            <% allBlogs.filter(item => item.id !== blog.id).slice(0, 3).forEach(item => { %>
                                <li style="margin-bottom: 12px;"><a href="/blog/<%= item.id %>"><i class="fa-solid fa-chevron-left" style="margin-left: 8px;"></i><%= item.title %></a></li>
                            <% }) %>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <%- include('../partials/footer') %>
    <%- include('../partials/scripts') %>
</body>
</html>


