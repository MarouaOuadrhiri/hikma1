<%- include('../partials/head', { title: university.title + ' - Hikma' }) %>

<body class="smooth-scroll-yes">

    <!-- Preloader Start -->
    <div id="preloader" class="preloader">
        <div class="animation-preloader">
            <div class="spinner"></div>
            <div class="txt-loading">
                <span data-text-preloader="H" class="letters-loading">H</span>
                <span data-text-preloader="I" class="letters-loading">I</span>
                <span data-text-preloader="K" class="letters-loading">K</span>
                <span data-text-preloader="M" class="letters-loading">M</span>
                <span data-text-preloader="A" class="letters-loading">A</span>
            </div>
            <p class="text-center">Loading</p>
        </div>
        <div class="loader">
            <div class="row">
                <div class="col-3 loader-section section-left"><div class="bg"></div></div>
                <div class="col-3 loader-section section-left"><div class="bg"></div></div>
                <div class="col-3 loader-section section-right"><div class="bg"></div></div>
                <div class="col-3 loader-section section-right"><div class="bg"></div></div>
            </div>
        </div>
    </div>

    <!-- GT Back To Top Start -->
    <button id="back-top" class="back-to-top show">
        <i class="fa-regular fa-arrow-up"></i>
    </button>

    <!-- GT MouseCursor Start -->
    <div class="mouseCursor cursor-outer"></div>
    <div class="mouseCursor cursor-inner"></div>

    <%- include('../partials/header') %>

    <!-- Breadcrumb-Wrapper Section Start -->
    <section class="breadcrumb-wrapper fix bg-cover" style="background-image: url('/assets/img/inner-page/breadcrumb.jpg');">
        <div class="shape">
            <img src="/assets/img/inner-page/shape.png" alt="img">
        </div>
        <div class="container">
            <div class="page-heading">
                <h1 class="breadcrumb-title"><%= university.title %></h1>
                <ul class="breadcrumb-list">
                    <li>
                        <a href="/">الرئيسية</a>
                    </li>
                    <li>
                        <i class="fa-solid fa-chevron-right"></i>
                    </li>
                    <li>
                        <a href="/universities">جامعاتنا</a>
                    </li>
                    <li>
                        <i class="fa-solid fa-chevron-right"></i>
                    </li>
                    <li style="color: #cc181e;">
                        <%= university.title %>
                    </li>
                </ul>
            </div>
        </div>
    </section>

    <!--News Section Start -->
    <section class="news-standard-section section-padding fix" dir="rtl">
        <div class="container">
            <div class="news-details-wrapper">
                <div class="row g-4">
                    <div class="col-lg-8 col-12 text-right">
                        <div class="news-details-post">
                            <div class="news-details-image">
                                <img src="<%= university.image %>" alt="<%= university.title %>" style="border-radius: 10px; width: 100%;">
                            </div>
                            <div class="details-content">
                                <ul class="news-list" style="justify-content: flex-start; gap: 25px; padding: 0; margin-bottom: 20px;">
                                    <li style="margin-left: 20px;">
                                        <i class="fa-solid fa-location-dot"></i>
                                        <span><%= university.city %></span>
                                    </li>
                                    <li style="margin-left: 20px;">
                                        <i class="fa-solid fa-calendar-days"></i>
                                        <span>تأسست عام: <%= university.established %></span>
                                    </li>
                                    <li>
                                        <i class="fa-solid fa-graduation-cap"></i>
                                        <span>جامعة <%= university.type %></span>
                                    </li>
                                </ul>
                                <h2 class="text-right mb-4">
                                    <%= university.title %>
                                </h2>
                                <p style="font-size: 16px; line-height: 1.8; color: #555;">
                                    <%= university.desc1 %>
                                </p>
                                <p class="mt-4 mb-4" style="font-size: 16px; line-height: 1.8; color: #555;">
                                    <%= university.desc2 %>
                                </p>
                                
                                <div class="sideber" style="border-right: 4px solid #cc181e; border-left: none; padding: 15px 25px; background: #f9f9f9; margin: 30px 0;">
                                    <h5 style="font-size: 18px; font-weight: 700; color: #174093; margin: 0; line-height: 1.6;">
                                        <%= university.ranking %>
                                    </h5>
                                </div>

                                <!-- Specialties list for the university -->
                                <div class="specialties-section mt-5" style="background: #ffffff; padding: 30px; border-radius: 15px; box-shadow: 0 5px 30px rgba(0,0,0,0.05); border: 1px solid #eee;">
                                    <h3 style="color: #174093; font-weight: 700; margin-bottom: 20px; font-size: 24px; border-bottom: 2px solid #f0f0f0; padding-bottom: 10px;">
                                        التخصصات المتاحة بالجامعة
                                    </h3>
                                    <p class="mb-4" style="color: #666;">نوفر لك قبولاً جامعياً مباشراً ومضموناً في التخصصات التالية المعتمدة لدى الجامعة:</p>
                                    <div class="row">
                                        <% university.specialties.forEach(spec => { %>
                                            <div class="col-md-6 mb-3">
                                                <div class="spec-card d-flex align-items-center" style="background: #f9f9f9; padding: 15px 20px; border-radius: 10px; border-right: 4px solid #cc181e;">
                                                    <i class="fa-solid fa-chevron-left" style="color: #cc181e; font-size: 14px; margin-left: 10px;"></i>
                                                    <span style="font-weight: 600; color: #333; font-size: 16px;"><%= spec %></span>
                                                </div>
                                            </div>
                                        <% }) %>
                                    </div>
                                </div>

                                <div class="row tag-share-wrap mt-5 mb-5">
                                    <div class="col-lg-8 col-12">
                                        <div class="tagcloud" style="text-align: right;">
                                            <span>البلد:</span>
                                            <a href="/universities/<%= university.country %>"><%= university.country === 'spain' ? 'إسبانيا' : (university.country === 'turkey' ? 'تركيا' : 'رومانيا') %></a>
                                            <a href="/universities"><%= university.city %></a>
                                            <a href="/universities"><%= university.type %></a>
                                        </div>
                                    </div>
                                    <div class="col-lg-4 col-12 mt-3 mt-lg-0 text-lg-left">
                                        <div class="social-share" style="justify-content: flex-start; gap: 10px;">
                                            <a href="#"><i class="fab fa-twitter"></i></a>
                                            <a href="#"><i class="fa-brands fa-youtube"></i></a>
                                            <a href="#"><i class="fab fa-linkedin-in"></i></a>
                                            <a href="#"><i class="fab fa-facebook-f"></i></a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Sidebar -->
                    <div class="col-lg-4 col-12">
                        <div class="main-sideber mr-lg-4 ml-lg-0">
                            <!-- Cities Categories Widget -->
                            <div class="news-sideber-box">
                                <div class="wid-title text-right">
                                    <h3>المدن الجامعية</h3>
                                </div>
                                <div class="news-widget-categories text-right">
                                    <ul style="padding: 0;">
                                        <li><a href="/universities/turkey"><i class="fa-solid fa-chevrons-left" style="margin-left: 8px; margin-right: 0;"></i> إسطنبول (تركيا)</a><span>(03)</span></li>
                                        <li><a href="/universities/spain/madrid"><i class="fa-solid fa-chevrons-left" style="margin-left: 8px; margin-right: 0;"></i> مدريد</a><span>(03)</span></li>
                                        <li><a href="/universities/spain/barcelona"><i class="fa-solid fa-chevrons-left" style="margin-left: 8px; margin-right: 0;"></i> برشلونة</a><span>(03)</span></li>
                                        <li><a href="/universities/spain/valencia-malaga"><i class="fa-solid fa-chevrons-left" style="margin-left: 8px; margin-right: 0;"></i> فالنسيا ومالقا</a><span>(03)</span></li>
                                        <li><a href="/universities/romania"><i class="fa-solid fa-chevrons-left" style="margin-left: 8px; margin-right: 0;"></i> رومانيا</a><span>(نشط)</span></li>
                                    </ul>
                                </div>
                            </div>

                            <!-- List of Universities Widget -->
                            <div class="news-sideber-box">
                                <div class="wid-title text-right">
                                    <h3>جامعات تركيا</h3>
                                </div>
                                <div class="news-widget-categories text-right">
                                    <ul style="padding: 0; font-size: 13px;">
                                        <% allUniversities.filter(u => u.country === 'turkey').forEach(uni => { %>
                                            <li><a href="/universities/details/<%= uni.id %>"><i class="fa-solid fa-chevron-left" style="margin-left: 8px;"></i> <%= uni.title %></a></li>
                                        <% }) %>
                                    </ul>
                                </div>
                            </div>

                            <!-- List of Universities Widget -->
                            <div class="news-sideber-box">
                                <div class="wid-title text-right">
                                    <h3>جامعات إسبانيا</h3>
                                </div>
                                <div class="news-widget-categories text-right">
                                    <ul style="padding: 0; font-size: 13px;">
                                        <% allUniversities.filter(u => u.country === 'spain').forEach(uni => { %>
                                            <li><a href="/universities/details/<%= uni.id %>"><i class="fa-solid fa-chevron-left" style="margin-left: 8px;"></i> <%= uni.title %></a></li>
                                        <% }) %>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <%- include('../partials/footer') %>
    <%- include('../partials/scripts') %>
</body>
</html>



