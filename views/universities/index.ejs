<%- include('../partials/head', { title: 'جامعاتنا - Hikma' }) %>

<body class="smooth-scroll-yes">

    <!-- Preloader Start -->
    <div id="preloader" class="preloader">
        <div class="animation-preloader">
            <div class="spinner"></div>
            <div class="txt-loading">
                <span data-text-preloader="H" class="letters-loading">H</span>
                <span data-text-preloader="I" class="letters-loading">I</span>
                <span data-text-preloader="K" class="letters-loading">K</span>
                <span data-text-preloader="M" class="letters-loading">M</span>
                <span data-text-preloader="A" class="letters-loading">A</span>
            </div>
            <p class="text-center">Loading</p>
        </div>
        <div class="loader">
            <div class="row">
                <div class="col-3 loader-section section-left"><div class="bg"></div></div>
                <div class="col-3 loader-section section-left"><div class="bg"></div></div>
                <div class="col-3 loader-section section-right"><div class="bg"></div></div>
                <div class="col-3 loader-section section-right"><div class="bg"></div></div>
            </div>
        </div>
    </div>

    <!-- GT Back To Top Start -->
    <button id="back-top" class="back-to-top show">
        <i class="fa-regular fa-arrow-up"></i>
    </button>

    <!-- GT MouseCursor Start -->
    <div class="mouseCursor cursor-outer"></div>
    <div class="mouseCursor cursor-inner"></div>

    <%- include('../partials/header') %>

    <!-- Breadcrumb-Wrapper Section Start -->
    <section class="breadcrumb-wrapper fix bg-cover" style="background-image: url('/assets/img/inner-page/breadcrumb.jpg');">
        <div class="shape">
            <img src="/assets/img/inner-page/shape.png" alt="img">
        </div>
        <div class="container">
            <div class="page-heading">
                <h1 class="breadcrumb-title">جامعاتنا الشريكة</h1>
                <ul class="breadcrumb-list">
                    <li>
                        <a href="/">الرئيسية</a>
                    </li>
                    <li>
                        <i class="fa-solid fa-chevron-right"></i>
                    </li>
                    <li>
                        جامعاتنا
                    </li>
                </ul>
            </div>
        </div>
    </section>

    <!--News Section Start -->
    <section class="news-standard-section section-padding fix" dir="rtl">
        <div class="container">
            <div class="news-standard-wrapper">
                <div class="row g-4">
                    <div class="col-lg-8 col-12 text-right">
                        
                        <!-- Turkey Section -->
                        <div class="news-standard-post">
                            <div class="news-image">
                                <img src="/assets/img/inner-page/blog/details-1.jpg" alt="Turkey Universities">
                            </div>
                            <div class="news-content">
                                <ul class="news-list" style="justify-content: flex-start; gap: 20px; padding: 0;">
                                    <li style="margin-left: 20px;">
                                        <i class="fa-solid fa-location-dot"></i>
                                        إسطنبول، تركيا
                                    </li>
                                    <li>
                                        <i class="fa-solid fa-graduation-cap"></i>
                                        <%= universities.filter(u => u.country === 'turkey').length %> جامعات رئيسية
                                    </li>
                                </ul>
                                <h3 class="text-right">
                                    <a href="/universities/turkey">
                                        الدراسة في جامعات تركيا المتميزة
                                    </a>
                                </h3>
                                <p>
                                    تعتبر تركيا واحدة من أكثر الوجهات التعليمية جذباً للطلاب بفضل جودة التعليم العالي والتكاليف الدراسية والخطط الأكاديمية باللغة الإنجليزية، وتنوع الحياة الثقافية.
                                </p>
                                <div class="university-quick-links mb-4">
                                    <h5 style="color: #174093; margin-bottom: 10px;">الجامعات المتاحة في تركيا:</h5>
                                    <ul style="list-style: none; padding: 0;">
                                        <% universities.filter(u => u.country === 'turkey').forEach(uni => { %>
                                            <li style="margin-bottom: 8px;">
                                                <a href="/universities/details/<%= uni.id %>" style="color: #cc181e;">
                                                    <i class="fa-solid fa-chevron-left" style="font-size: 12px; margin-left: 5px;"></i>
                                                    <%= uni.title %> (<%= uni.type %>)
                                                </a>
                                            </li>
                                        <% }) %>
                                    </ul>
                                </div>
                                <a href="/universities/turkey" class="theme-btn" style="display: inline-flex; align-items: center; flex-direction: row-reverse; padding: 6px 6px 6px 24px;">
                                    دليل تركيا الشامل
                                    <i class="fa-solid fa-arrow-right" style="margin-left: 20px; margin-right: 0;"></i>
                                </a>
                            </div>
                        </div>

                        <!-- Spain Sections Grouped by Cities -->
                        <% 
                        const spainCities = [
                            { key: 'madrid', name: 'مدريد', img: '/assets/img/home-1/news/news-13.jpg', desc: 'تعد مدريد وجهة تعليمية عالمية رائدة، حيث تضم جامعات عريقة تقدم برامج معترف بها دولياً. بيئتها الثقافية النابضة بالحياة وفرص العمل تجعلها الخيار الأول.' },
                            { key: 'barcelona', name: 'برشلونة', img: '/assets/img/home-1/news/news-14.jpg', desc: 'برشلونة تجمع بين جودة التعليم العالي والحياة المتوسطية الفريدة. جامعاتها مصنفة ضمن الأفضل في أوروبا وتتميز بأبحاثها وتخصصاتها المتنوعة.' },
                            { key: 'valencia-malaga', name: 'فالنسيا ومالقا', img: '/assets/img/home-1/news/news-15.jpg', desc: 'توفر فالنسيا ومالقا بيئة دراسية مريحة بأسعار معقولة مقارنة بالمدن الكبرى. جامعاتها الحكومية تتميز ببيئة أكاديمية ممتازة وتستقطب آلاف الطلاب.' }
                        ];
                        
                        spainCities.forEach(cityObj => {
                            const cityUnis = universities.filter(u => {
                                if (u.country !== 'spain') return false;
                                if (cityObj.key === 'madrid') return u.city === 'مدريد';
                                if (cityObj.key === 'barcelona') return u.city === 'برشلونة';
                                if (cityObj.key === 'valencia-malaga') return u.city === 'فالنسيا' || u.city === 'مالقا';
                                return false;
                            });
                        %>
                            <div class="news-standard-post">
                                <div class="news-image">
                                    <img src="<%= cityObj.img %>" alt="<%= cityObj.name %> Universities">
                                </div>
                                <div class="news-content">
                                    <ul class="news-list" style="justify-content: flex-start; gap: 20px; padding: 0;">
                                        <li style="margin-left: 20px;">
                                            <i class="fa-solid fa-location-dot"></i>
                                            <%= cityObj.name %>، إسبانيا
                                        </li>
                                        <li>
                                            <i class="fa-solid fa-graduation-cap"></i>
                                            <%= cityUnis.length %> جامعات شريكة
                                        </li>
                                    </ul>
                                    <h3 class="text-right">
                                        <a href="/universities/spain/<%= cityObj.key %>">
                                            الدراسة في جامعات <%= cityObj.name %>
                                        </a>
                                    </h3>
                                    <p><%= cityObj.desc %></p>
                                    <div class="university-quick-links mb-4">
                                        <h5 style="color: #174093; margin-bottom: 10px;">الجامعات المتاحة:</h5>
                                        <ul style="list-style: none; padding: 0;">
                                            <% cityUnis.forEach(uni => { %>
                                                <li style="margin-bottom: 8px;">
                                                    <a href="/universities/details/<%= uni.id %>" style="color: #cc181e;">
                                                        <i class="fa-solid fa-chevron-left" style="font-size: 12px; margin-left: 5px;"></i>
                                                        <%= uni.title %>
                                                    </a>
                                                </li>
                                            <% }) %>
                                        </ul>
                                    </div>
                                    <a href="/universities/spain/<%= cityObj.key %>" class="theme-btn" style="display: inline-flex; align-items: center; flex-direction: row-reverse; padding: 6px 6px 6px 24px;">
                                        تصفح جامعات <%= cityObj.name %>
                                        <i class="fa-solid fa-arrow-right" style="margin-left: 20px; margin-right: 0;"></i>
                                    </a>
                                </div>
                            </div>
                        <% }) %>

                    </div>

                    <!-- Sidebar -->
                    <div class="col-lg-4 col-12">
                        <div class="main-sideber mr-lg-4 ml-lg-0">
                            <!-- Categories Widget -->
                            <div class="news-sideber-box">
                                <div class="wid-title text-right">
                                    <h3>المدن الجامعية</h3>
                                </div>
                                <div class="news-widget-categories text-right">
                                    <ul style="padding: 0;">
                                        <li><a href="/universities/turkey"><i class="fa-solid fa-chevrons-left" style="margin-left: 8px; margin-right: 0;"></i> إسطنبول (تركيا)</a><span>(03)</span></li>
                                        <li><a href="/universities/spain/madrid"><i class="fa-solid fa-chevrons-left" style="margin-left: 8px; margin-right: 0;"></i> مدريد</a><span>(03)</span></li>
                                        <li><a href="/universities/spain/barcelona"><i class="fa-solid fa-chevrons-left" style="margin-left: 8px; margin-right: 0;"></i> برشلونة</a><span>(03)</span></li>
                                        <li><a href="/universities/spain/valencia-malaga"><i class="fa-solid fa-chevrons-left" style="margin-left: 8px; margin-right: 0;"></i> فالنسيا ومالقا</a><span>(03)</span></li>
                                        <li><a href="/universities/romania"><i class="fa-solid fa-chevrons-left" style="margin-left: 8px; margin-right: 0;"></i> رومانيا</a><span>(نشط)</span></li>
                                    </ul>
                                </div>
                            </div>

                            <!-- Why Study in Spain Widget -->
                            <div class="news-sideber-box">
                                <div class="wid-title text-right">
                                    <h3>مزايا الدراسة بالخارج</h3>
                                </div>
                                <div class="recent-post-area text-right">
                                    <div class="recent-items" style="flex-direction: row-reverse; justify-content: flex-start;">
                                        <div class="recent-content" style="padding-right: 0; padding-left: 15px;">
                                            <h6>
                                                <a href="/universities/spain">
                                                    شهادات أوروبية معترف بها دولياً في جميع أنحاء العالم.
                                                </a>
                                            </h6>
                                        </div>
                                    </div>
                                    <div class="recent-items" style="flex-direction: row-reverse; justify-content: flex-start;">
                                        <div class="recent-content" style="padding-right: 0; padding-left: 15px;">
                                            <h6>
                                                <a href="/universities/turkey">
                                                    جامعات تركية متميزة تقدم برامجها باللغة الإنجليزية بالكامل.
                                                </a>
                                            </h6>
                                        </div>
                                    </div>
                                    <div class="recent-items" style="flex-direction: row-reverse; justify-content: flex-start;">
                                        <div class="recent-content" style="padding-right: 0; padding-left: 15px;">
                                            <h6>
                                                <a href="/universities/romania">
                                                    رومانيا - تكاليف دراسية ومعيشية منخفضة جداً بالاتحاد الأوروبي.
                                                </a>
                                            </h6>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <%- include('../partials/footer') %>
    <%- include('../partials/scripts') %>
</body>
</html>



